<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Séquence BCG : CG/YYYY/XXXX -->
    <record id="seq_gica_commande_globale" model="ir.sequence">
        <field name="name">Commande Globale GICA</field>
        <field name="code">gica.commande.globale</field>
        <field name="prefix">CG/%(year)s/</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Séquence BC : BC/YYYY/XXXX -->
    <record id="seq_gica_bon_commande" model="ir.sequence">
        <field name="name">Bon de Commande GICA</field>
        <field name="code">gica.bon.commande</field>
        <field name="prefix">BC/%(year)s/</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>