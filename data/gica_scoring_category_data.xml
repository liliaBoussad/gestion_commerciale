<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- PLATINUM -->
    <record id="scoring_category_platinum" model="gica.scoring.category">
        <field name="name">Platinum</field>
        <field name="niveau">platinum</field>
        <field name="score_minimum">90</field>
        <field name="delai_paiement">30</field>
        <field name="paiement_anticipe">False</field>
        <field name="mode_cheque_certifie">True</field>
        <field name="mode_cheque_ordinaire">True</field>
        <field name="mode_virement">True</field>
        <field name="mode_lettre_change">True</field>
        <field name="mode_versement">True</field>
        <field name="mode_cib">True</field>
        <field name="remise_volume">True</field>
        <field name="description">
Score ≥ 90 pts. Vente à terme 30 jours.
Tous les modes de paiement autorisés.
Remise sur volume selon objectifs trimestriels.
        </field>
    </record>

