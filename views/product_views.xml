<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════
         Héritage product.template — ajout champs GICA
         ══════════════════════════════════════════════════════ -->
    <record id="view_product_template_gica_form" model="ir.ui.view">
        <field name="name">product.template.gica.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="is_gica_product" widget="boolean_toggle"/>
                <field name="type_ciment" invisible="not is_gica_product"/>
            </xpath>
        </field>
    </record>

    <!-- Héritage product.product — ajout conditionnement GICA -->
    <record id="view_product_product_gica_form" model="ir.ui.view">
        <field name="name">product.product.gica.form</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_code']" position="after">
                <field name="conditionnement_gica"/>
            </xpath>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════
         Action — Catalogue GICA (filtre produits GICA uniquement)
         ══════════════════════════════════════════════════════ -->
    <record id="action_gica_product" model="ir.actions.act_window">
        <field name="name">Catalogue GICA</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_gica_product', '=', True)]</field>
        <field name="context">{'default_is_gica_product': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucun produit GICA
            </p>
            <p>
                Créez un produit et cochez "Produit GICA" pour l'ajouter au catalogue.
            </p>
        </field>
    </record>

</odoo>